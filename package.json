{
  "name": "einat-website",
  "private": true,
  "workspaces": [
    "server"
  ],
  "scripts": {
    "build": "cd server && npm run build && npx prisma generate",
    "start": "cd server && npx prisma migrate deploy && node dist/index.js",
    "dev:server": "cd server && npm run dev",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:seed": "cd server && npx prisma db seed",
    "db:studio": "cd server && npx prisma studio",
    "e2e": "cd e2e && npx playwright test",
    "e2e:ui": "cd e2e && npx playwright test --ui",
    "e2e:report": "cd e2e && npx playwright show-report ../playwright-report",
    "e2e:install": "npx playwright install --with-deps chromium"
  },
  "engines": {
    "node": ">=20.0.0"
  },

  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "tsx": "^4.22.3"
  }
}
